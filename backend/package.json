{
  "name": "agniveer-samiti-backend",
  "version": "1.0.0",
  "description": "Backend API for Akhil Gujarat Agniveer Samiti management system",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed:districts": "node scripts/seedGujaratDistricts.js",
    "seed:admin": "node scripts/createAdmin.js",
    "seed:leadership": "node scripts/seedLeadership.js",
    "seed:all": "npm run seed:districts && npm run seed:admin && npm run seed:leadership"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.6.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
